# --- CommonPlace : configuration ---
# Copie ce fichier en .env et remplis les valeurs.

# Bot Telegram (obligatoire pour la capture mobile)
# Token donne par @BotFather
TELEGRAM_BOT_TOKEN=
# Optionnel : limite la capture a un seul chat (ton chat_id).
# Trouve-le avec : python3 -m commonplace.run whoami
TELEGRAM_ALLOWED_CHAT_ID=

# YouTube (playlist non listee) — optionnel
# Cle API : https://console.cloud.google.com (activer "YouTube Data API v3")
YOUTUBE_API_KEY=
YOUTUBE_PLAYLIST_ID=PLrgyJ0gFJHRJrzFTTSGV0y0yYTFhIsqEC

# Cookies navigateur (format Netscape) pour Instagram/TikTok prive — optionnel
COOKIES_FILE=

# Plateformes ou on ne garde que le lien + la miniature (pas la video entiere).
# Liste separee par des virgules. Defaut : youtube. Vide = tout telecharger.
THUMBNAIL_ONLY_PLATFORMS=youtube

# Cle optionnelle pour proteger l'endpoint /add (raccourci iPhone).
# Vide = pas de protection. Recommande si le serveur est expose largement.
ADD_KEY=

# Digestion nocturne : dossier ou ecrire les fiches md par theme.
# Ex: /Users/alysse-openclaw/wiki/resources/commonplace  (vide = data/digest/)
WIKI_DIGEST_DIR=
# Mettre 1 pour que la digestion commit+push automatiquement (si le dossier est dans un repo git)
WIKI_DIGEST_GIT=

# Seuil de decoupe d'une liste trop grosse (reorg)
SPLIT_THRESHOLD=30

# Recuperation des Enregistres Instagram (instaloader, session connectee).
# ATTENTION : Instagram peut bloquer un compte sur-automatise. A lancer avec parcimonie.
# Setup : pip3 install instaloader ; instaloader -l TON_USERNAME (une fois)
IG_USERNAME=
SAVED_MAX_PER_RUN=30
SAVED_STOP_AFTER_KNOWN=10
SAVED_PAUSE=2.0

# Limite de traitement par execution
MAX_PER_RUN=25
